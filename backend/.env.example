# Copier ce fichier en .env et ajuster les valeurs si besoin.
# Le backend fonctionne avec les valeurs par défaut sans .env.

# Taille de la grille (carrée, N x N)
GRID_SIZE=20

# Intervalle entre chaque tick du jeu (millisecondes)
TICK_INTERVAL_MS=150

# Hyperparamètres Q-Learning
RL_ALPHA=0.1
RL_GAMMA=0.9
RL_EPSILON_START=1.0
RL_EPSILON_MIN=0.01
RL_EPSILON_DECAY=0.995
